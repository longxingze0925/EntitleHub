POSTGRES_DB=user_admin
POSTGRES_USER=app_user
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
REDIS_PASSWORD=replace-with-a-strong-redis-password

COMPOSE_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
POSTGRES_EXPORTER_HOST_PORT=9187
REDIS_EXPORTER_HOST_PORT=9121
BACKEND_HOST_PORT=8080
ADMIN_HOST_PORT=5173
PROMETHEUS_HOST_PORT=9090
ALERTMANAGER_HOST_PORT=9093
GRAFANA_HOST_PORT=3000
ALERTMANAGER_CONFIG_PATH=./ops/alertmanager/alertmanager.yml
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password
BACKEND_IMAGE=ghcr.io/longxingze0925/entitlehub-backend:main
ADMIN_IMAGE=ghcr.io/longxingze0925/entitlehub-admin:main
PROMETHEUS_IMAGE=prom/prometheus:v3.12.0
ALERTMANAGER_IMAGE=prom/alertmanager:v0.32.2
GRAFANA_IMAGE=grafana/grafana:13.0.2
POSTGRES_EXPORTER_IMAGE=quay.io/prometheuscommunity/postgres-exporter:v0.19.1
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:v1.85.0

APP_ENV=development
APP_NAME=user-admin-backend
APP_BASE_URL=http://localhost:5173
APP_HOST=0.0.0.0
APP_PORT=8080
APP_LOG_LEVEL=info,user_admin_backend=debug
ALERTMANAGER_WEBHOOK_TOKEN=
ALERT_DELIVERY_TIMEOUT_SECONDS=10
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUSTED_PROXIES=

DATABASE_URL=postgres://app_user:replace-with-a-strong-postgres-password@postgres:5432/user_admin
DATABASE_MAX_CONNECTIONS=5
DATABASE_CONNECT_TIMEOUT_SECONDS=5
REDIS_URL=redis://:replace-with-a-strong-redis-password@redis:6379
REDIS_CONNECT_TIMEOUT_SECONDS=5

EMAIL_OUTBOX_WORKER_ENABLED=false
EMAIL_OUTBOX_POLL_INTERVAL_SECONDS=15
EMAIL_OUTBOX_PROCESSING_TIMEOUT_SECONDS=300
EMAIL_OUTBOX_BATCH_SIZE=10
EMAIL_OUTBOX_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

SESSION_SECRET=replace-with-at-least-32-random-bytes
TOKEN_HASH_PEPPER=replace-with-at-least-32-random-bytes
REFRESH_TOKEN_PEPPER=replace-with-at-least-32-random-bytes
CSRF_SECRET=replace-with-at-least-32-random-bytes
MASTER_KEY=replace-with-base64-encoded-32-bytes
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=client-sdk
COOKIE_SECURE=false

ADMIN_SESSION_TTL_SECONDS=86400
CLIENT_ACCESS_TOKEN_TTL_SECONDS=900
CLIENT_REFRESH_TOKEN_TTL_SECONDS=2592000
CLIENT_SESSION_TTL_SECONDS=2592000
DOWNLOAD_TOKEN_TTL_SECONDS=300
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ACTIVATION_RATE_LIMIT_MAX=20
ACTIVATION_RATE_LIMIT_WINDOW_SECONDS=300
REFRESH_RATE_LIMIT_MAX=60
REFRESH_RATE_LIMIT_WINDOW_SECONDS=300
HEARTBEAT_RATE_LIMIT_MAX=120
HEARTBEAT_RATE_LIMIT_WINDOW_SECONDS=60
CLIENT_ACTION_RATE_LIMIT_MAX=120
CLIENT_ACTION_RATE_LIMIT_WINDOW_SECONDS=60
DOWNLOAD_RATE_LIMIT_MAX=30
DOWNLOAD_RATE_LIMIT_WINDOW_SECONDS=300
AI_GATEWAY_RATE_LIMIT_MAX=120
AI_GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

OBJECT_STORAGE_MODE=local
OBJECT_STORAGE_LOCAL_ROOT=/app/storage
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
