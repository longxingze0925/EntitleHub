APP_ENV=development
APP_NAME=user-admin-backend
APP_BASE_URL=http://127.0.0.1:5173
APP_HOST=127.0.0.1
APP_PORT=8080
APP_LOG_LEVEL=info,user_admin_backend=debug
ALERTMANAGER_WEBHOOK_TOKEN=
ALERT_DELIVERY_TIMEOUT_SECONDS=10
ALLOWED_ORIGINS=http://127.0.0.1:5173
TRUSTED_PROXIES=127.0.0.1,::1
DATABASE_URL=postgres://app_user:app_password@127.0.0.1:5432/user_admin
DATABASE_MAX_CONNECTIONS=5
DATABASE_CONNECT_TIMEOUT_SECONDS=5
REDIS_URL=redis://127.0.0.1:6379
REDIS_CONNECT_TIMEOUT_SECONDS=5
EMAIL_OUTBOX_WORKER_ENABLED=false
EMAIL_OUTBOX_POLL_INTERVAL_SECONDS=15
EMAIL_OUTBOX_PROCESSING_TIMEOUT_SECONDS=300
EMAIL_OUTBOX_BATCH_SIZE=10
EMAIL_OUTBOX_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SESSION_SECRET=change-me-at-least-32-random-bytes
TOKEN_HASH_PEPPER=change-me-at-least-32-random-bytes
REFRESH_TOKEN_PEPPER=change-me-at-least-32-random-bytes
CSRF_SECRET=change-me-at-least-32-random-bytes
MASTER_KEY=base64-encoded-32-bytes
JWT_ISSUER=http://127.0.0.1:8080
JWT_AUDIENCE=client-sdk
COOKIE_SECURE=false
ADMIN_SESSION_TTL_SECONDS=86400
CLIENT_ACCESS_TOKEN_TTL_SECONDS=900
CLIENT_REFRESH_TOKEN_TTL_SECONDS=2592000
CLIENT_SESSION_TTL_SECONDS=2592000
DOWNLOAD_TOKEN_TTL_SECONDS=300
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ACTIVATION_RATE_LIMIT_MAX=20
ACTIVATION_RATE_LIMIT_WINDOW_SECONDS=300
REFRESH_RATE_LIMIT_MAX=60
REFRESH_RATE_LIMIT_WINDOW_SECONDS=300
HEARTBEAT_RATE_LIMIT_MAX=120
HEARTBEAT_RATE_LIMIT_WINDOW_SECONDS=60
DOWNLOAD_RATE_LIMIT_MAX=30
DOWNLOAD_RATE_LIMIT_WINDOW_SECONDS=300
OBJECT_STORAGE_MODE=local
OBJECT_STORAGE_LOCAL_ROOT=./storage
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
